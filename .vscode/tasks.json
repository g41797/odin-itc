{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Odin",
            "type": "shell",
            "command": "/home/g41797/.local/bin/odin",
            "args": [
                "build",
                "${workspaceFolder}",
                "-debug",
                "-o:none",
                "-out:${workspaceFolder}/${workspaceFolderBasename}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build Tests",
            "type": "shell",
            "command": "/home/g41797/.local/bin/odin",
            "args": [
                "build",
                "${workspaceFolder}/${input:testPackage}",
                "-build-mode:test",
                "-debug",
                "-o:none",
                "-out:${workspaceFolder}/debug_current"
            ],
            "group": "build",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "testPackage",
            "type": "pickString",
            "description": "Select test package",
            "options": [
                { "label": "mpsc/",             "value": "mpsc" },
                { "label": "wakeup/",           "value": "wakeup" },
                { "label": "tests/",            "value": "tests" },
                { "label": "tests/mbox/",       "value": "tests/mbox" },
                { "label": "tests/loop_mbox/",  "value": "tests/loop_mbox" },
                { "label": "tests/nbio_mbox/",  "value": "tests/nbio_mbox" },
                { "label": "tests/pool/",       "value": "tests/pool" }
            ]
        }
    ]
}
